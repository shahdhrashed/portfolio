# Copy this file to .env.local and fill in the values once a Sanity project exists.
# Until these are set, the site runs on bundled sample content automatically.

# From sanity.io/manage (your project's settings)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Used for absolute URLs in sitemap.xml / robots.txt (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://shahd.example.com
